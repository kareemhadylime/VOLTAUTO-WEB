# Public site URL — used as base for absolute URLs in metadata, sitemap, llms.txt
NEXT_PUBLIC_SITE_URL=https://voltauto-website.vercel.app

# Supabase — same project as the voltauto-pricing CRM/pricing app
# (lookup in pricing app's .env or in Vercel dashboard for the voltauto-pricing project)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — never NEXT_PUBLIC_-prefixed
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# reCAPTCHA v3 — optional (Phase 2 falls back to dev-pass without these)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
